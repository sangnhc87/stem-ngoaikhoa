# Dia chi Supabase Project URL, lay trong Supabase > Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon public key. Khoa nay duoc phep dung o frontend.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service_role key. Tuyet doi khong chia se cong khai, khong dua len frontend.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Bucket Supabase Storage de luu file thu thach. Migration mac dinh tao bucket nay.
SUPABASE_STORAGE_BUCKET=challenge-files

# Mat khau giao vien dung de vao /admin.
ADMIN_PASSWORD=change-this-admin-password

# Bi mat ky cookie dang nhap. Hay dung chuoi ngau nhien it nhat 32 ky tu.
SESSION_SECRET=replace-with-at-least-32-random-characters

# Bi mat hash dap an. Hay dung chuoi khac SESSION_SECRET va it nhat 32 ky tu.
ANSWER_HASH_SECRET=replace-with-a-separate-32-character-secret

# Bi mat hash IP trong log nop bai. Hay dung chuoi ngau nhien it nhat 32 ky tu.
IP_HASH_SECRET=replace-with-another-32-character-secret

# Dia chi website. Local dung http://localhost:3000; production dung URL Vercel.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Giup Vercel dung dung pnpm duoc khai bao trong package.json.
ENABLE_EXPERIMENTAL_COREPACK=1
